# -----------------------------
# DATABASE CONFIG
# -----------------------------
PGHOST=seu_host_aqui
PGPORT=5432
PGDATABASE=seu_banco_aqui
PGUSER=seu_usuario_aqui
PGPASSWORD=sua_senha_aqui

# -----------------------------
# OPTIONAL DATABASE URL
# -----------------------------
DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/banco

# -----------------------------
# DASHBOARD CONFIG
# -----------------------------
APP_NAME=Data7 Financial Dashboard
APP_ENV=development
APP_PORT=8501

# -----------------------------
# BUSINESS TARGETS
# -----------------------------
META_SEMANAL=90000
META_MENSAL=350000

# -----------------------------
# FILTER DEFAULTS
# -----------------------------
ANO_PADRAO=2026
CLIENTE_PADRAO=Todos

# -----------------------------
# EMAIL ALERTS (future use)
# -----------------------------
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_DESTINO=

# -----------------------------
# LOG CONFIG
# -----------------------------
LOG_LEVEL=INFO
